{
  "name": "mip-backend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "prisma generate && tsc",
    "db:generate": "prisma generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:push": "prisma db push",
    "db:seed": "tsx src/db/seed-from-csv.ts",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.4.0",
    "@langchain/core": "^1.1.48",
    "@langchain/groq": "^1.2.1",
    "@langchain/openai": "^1.4.7",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "axios": "^1.16.1",
    "cors": "^2.8.6",
    "docx": "^9.7.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "groq-sdk": "^1.2.0",
    "jsonwebtoken": "^9.0.3",
    "langsmith": "^0.7.5",
    "node-cron": "^4.2.1",
    "openai": "^6.42.0",
    "pg": "^8.21.0",
    "pptxgenjs": "^4.0.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.1",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
